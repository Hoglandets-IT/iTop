<turbo-stream action="{{ oUIBlock.GetAction() }}" target="{{ oUIBlock.GetTarget() }}">
    <template>
        {%- block iboContentBlockContainer -%}
            {% for oSubBlock in oUIBlock.GetSubBlocks() %}
                {{ render_block(oSubBlock, {aPage: aPage}) }}
            {% endfor %}
        {%- endblock -%}
    </template>
</turbo-stream>